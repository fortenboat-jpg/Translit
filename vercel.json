{
  "version": 2,
  "functions": {
    "api/ocr.js":      { "maxDuration": 30 },
    "api/translate.js":{ "maxDuration": 60 },
    "api/checkout.js": { "maxDuration": 10 },
    "api/webhook.js":  { "maxDuration": 60 }
  },
  "headers": [
    {
      "source": "/sitemap.xml",
      "headers": [
        { "key": "Content-Type", "value": "application/xml" }
      ]
    },
    {
      "source": "/robots.txt",
      "headers": [
        { "key": "Content-Type", "value": "text/plain" }
      ]
    }
  ]
}
